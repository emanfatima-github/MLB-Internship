   "source": [
    "import json\n",
    "\n",
    "students = [\n",
    "    {\"name\": \"Aimen\", \"age\": 20, \"grade\": \"A\"},\n",
    "    {\"name\": \"Ahmed\", \"age\": 22, \"grade\": \"B+\"},\n",
    "    {\"name\": \"Maryam\", \"age\": 21, \"grade\": \"A+\"}\n",
    "]\n",
    "\n",
    "with open(\"student_records.json\", \"w\") as f:\n",
    "    json.dump(students, f, indent=4)\n",
    "\n",
    "print(\"student_records.json created!\")"
   ]
  },
